generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Block {
  id          String   @id @default(uuid())
  description String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  units Unit[]

  @@map("blocks")
}

model Unit {
  id          String   @id @default(uuid())
  description String
  blockId     String
  sqFt        Int
  inceptionDt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  block         Block                 @relation(fields: [blockId], references: [id], onDelete: Restrict)
  owners        UnitOwner[]
  residents     UnitResident[]
  contributions Contribution[]

  @@unique([blockId, description])
  @@index([blockId])
  @@map("units")
}

model GenderType {
  id          Int      @id
  description String   @unique
  createdAt   DateTime @default(now())

  individuals Individual[]

  @@map("gender_types")
}

model Individual {
  id               String   @id @default(uuid())
  fName            String
  mName            String?
  sName            String
  eMail            String   @unique
  mobile           String   @unique
  altMobile        String?
  genderId         Int
  isSystemIdentity Boolean  @default(false)
  systemTag        String?  @unique
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  genderType    GenderType        @relation(fields: [genderId], references: [id], onDelete: Restrict)
  ownedUnits    UnitOwner[]
  livedUnits    UnitResident[]
  contributions Contribution[]    @relation("ContributionDepositedBy")

  @@index([sName, fName])
  @@map("individuals")
}

model AppUser {
  id           String   @id @default(cuid())
  email        String   @unique
  displayName  String
  passwordHash String
  role         String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([role])
  @@map("app_users")
}

model UnitOwner {
  id        String    @id @default(uuid())
  unitId    String
  indId     String
  fromDt    DateTime
  toDt      DateTime?
  createdAt DateTime  @default(now())

  unit       Unit       @relation(fields: [unitId], references: [id], onDelete: Restrict)
  individual Individual @relation(fields: [indId], references: [id], onDelete: Restrict)

  @@index([unitId, fromDt, toDt])
  @@index([indId, fromDt, toDt])
  @@map("unit_owners")
}

model UnitResident {
  id        String    @id @default(uuid())
  unitId    String
  indId     String
  fromDt    DateTime
  toDt      DateTime?
  createdAt DateTime  @default(now())

  unit       Unit       @relation(fields: [unitId], references: [id], onDelete: Restrict)
  individual Individual @relation(fields: [indId], references: [id], onDelete: Restrict)

  @@index([unitId, fromDt, toDt])
  @@index([indId, fromDt, toDt])
  @@map("unit_residents")
}

model ContributionHead {
  id          Int      @id @default(autoincrement())
  description String   @unique
  payUnit     Int
  period      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rates         ContributionRate[]
  contributions Contribution[]

  @@map("contribution_heads")
}

model ContributionRate {
  id                 Int       @id @default(autoincrement())
  contributionHeadId Int
  reference          String?
  fromDt             DateTime
  toDt               DateTime?
  amt                Decimal   @db.Decimal(12, 2)
  createdAt          DateTime  @default(now())

  contributionHead ContributionHead @relation(fields: [contributionHeadId], references: [id], onDelete: Restrict)
  details          ContributionDetail[]

  @@index([contributionHeadId, fromDt, toDt])
  @@map("contribution_rates")
}

model ContributionPeriod {
  id        Int      @id @default(autoincrement())
  refMonth  Int
  refYear   Int
  createdAt DateTime @default(now())

  details ContributionDetail[]

  @@unique([refYear, refMonth])
  @@index([refYear])
  @@map("contribution_periods")
}

model Contribution {
  id                         Int      @id @default(autoincrement())
  unitId                     String
  contributionHeadId         Int
  quantity                   Int
  periodCount                Int
  transactionId              String
  transactionDateTime        DateTime
  depositedBy                String
  inputComment               String?
  actorUserId                String?
  actorRole                  String?
  correctionOfContributionId Int?
  correctionReasonCode       String?
  correctionReasonText       String?
  createdAt                  DateTime @default(now())

  unit              Unit              @relation(fields: [unitId], references: [id], onDelete: Restrict)
  contributionHead  ContributionHead  @relation(fields: [contributionHeadId], references: [id], onDelete: Restrict)
  depositor         Individual        @relation("ContributionDepositedBy", fields: [depositedBy], references: [id], onDelete: Restrict)
  correctionOf      Contribution?     @relation("ContributionCorrection", fields: [correctionOfContributionId], references: [id], onDelete: Restrict)
  correctedBy       Contribution[]    @relation("ContributionCorrection")
  details           ContributionDetail[]

  @@index([unitId, contributionHeadId])
  @@index([transactionDateTime])
  @@index([depositedBy])
  @@index([correctionOfContributionId])
  @@map("contributions")
}

model ContributionDetail {
  id                   Int      @id @default(autoincrement())
  contributionId       Int
  contributionPeriodId Int
  contributionRateId   Int?
  amt                  Decimal  @db.Decimal(12, 2)
  appliedRate          Decimal? @db.Decimal(12, 4)
  appliedRateReference String?
  createdAt            DateTime @default(now())

  contribution       Contribution     @relation(fields: [contributionId], references: [id], onDelete: Restrict)
  contributionPeriod ContributionPeriod @relation(fields: [contributionPeriodId], references: [id], onDelete: Restrict)
  contributionRate   ContributionRate? @relation(fields: [contributionRateId], references: [id], onDelete: Restrict)

  @@unique([contributionId, contributionPeriodId])
  @@index([contributionPeriodId])
  @@index([contributionRateId])
  @@map("contribution_details")
}
